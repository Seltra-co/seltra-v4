# ─── Seltra Web App – Environment Variables ────────────────────────────
#
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# Your backend API base URL (NestJS / Express / whatever you're running)
VITE_API_BASE_URL=http://localhost:3001

# Turn this on while the backend is not ready.
# Auth, dashboard conversations, agent replies, and waitlist submissions use local browser storage.
VITE_USE_MOCK_API=false

# The storefront app URL (Next.js storefront from apps/storefront)
# The dashboard embeds this as an iframe preview.
VITE_STOREFRONT_URL=http://localhost:8080

# Paystack public key for storefront checkout.
VITE_PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxx

# Backend AI budget controls.
# Keep product catalogs deterministic by default so store creation does not spend a second Groq call.
SELTRA_LLM_PRODUCTS=false
SELTRA_REMOTE_PRODUCT_IMAGES=false
GROQ_TPM_BUDGET=4800
GROQ_MAX_TOKENS=500
