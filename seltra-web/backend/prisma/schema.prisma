generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tenants      Tenant[]
}

model Tenant {
  id                    String            @id @default(uuid())
  ownerId               String?
  name                  String
  slug                  String            @unique
  businessType          String?
  targetAudience        String?
  platform              String            @default("Seltra")
  status                String            @default("active")
  canonical             Json
  storeUrl              String?
  storefrontCode        String?
  storefrontVersion     Int               @default(0)
  storefrontGeneratedAt DateTime?
  storeDNA              Json?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  categories            Category[]
  customers             Customer[]
  ledger                MerchantLedger?
  orders                Order[]
  paymentProviders      PaymentProvider[]
  products              Product[]
  shippingZones         ShippingZone[]
  owner                 User?             @relation(fields: [ownerId], references: [id])

  @@index([ownerId])
}

model Conversation {
  id        String    @id
  title     String
  userId    String    @map("user_id")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  messages  Message[]

  @@index([userId, updatedAt(sort: Desc)], map: "Conversation_user_updated_idx")
  @@map("Conversation")
}

model Message {
  id             String       @id
  conversationId String       @map("conversation_id")
  userId         String       @map("user_id")
  role           String
  content        String
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt], map: "Message_conversation_created_idx")
  @@map("Message")
}

model Category {
  id       String @id @default(uuid())
  tenantId String
  name     String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name])
}

model Product {
  id          String           @id @default(uuid())
  tenantId    String
  name        String
  description String?
  price       Decimal          @db.Decimal(10, 2)
  currency    String           @default("GHS")
  category    String?
  sku         String?
  tags        Json?
  status      String           @default("active")
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  images      ProductImage[]
  variants    ProductVariant[]
}

model ProductImage {
  id        String  @id @default(uuid())
  productId String
  url       String
  isPrimary Boolean @default(false)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductVariant {
  id        String  @id @default(uuid())
  productId String
  name      String
  value     String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model PaymentProvider {
  id       String @id @default(uuid())
  tenantId String
  provider String
  config   Json?
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, provider])
}

model ShippingZone {
  id           String  @id @default(uuid())
  tenantId     String
  name         String
  deliveryTime String?
  fee          String?
  metadata     Json?
  tenant       Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name])
}

model Order {
  id              String              @id @default(uuid())
  tenantId        String
  customerId      String?
  customerEmail   String
  customerName    String?
  customerPhone   String?
  shippingAddress String?
  shippingCity    String?
  shippingCountry String?
  marketingOptIn  Boolean             @default(false)
  totalAmount     Decimal             @db.Decimal(10, 2)
  currency        String              @default("GHS")
  status          String              @default("pending")
  paystackRef     String?
  items           Json
  disbursed       Boolean             @default(false)
  disbursedAt     DateTime?
  seltraFee       Decimal?            @db.Decimal(10, 2)
  merchantAmount  Decimal?            @db.Decimal(10, 2)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  ledgerTx        LedgerTransaction[]
  customer        Customer?           @relation(fields: [customerId], references: [id])
  tenant          Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, customerEmail])
  @@index([customerId])
}

model Customer {
  id             String   @id @default(uuid())
  tenantId       String
  email          String
  name           String?
  phone          String?
  address        String?
  city           String?
  country        String?
  marketingOptIn Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orders         Order[]

  @@unique([tenantId, email])
  @@index([tenantId, updatedAt])
}

model MerchantLedger {
  id           String              @id @default(uuid())
  tenantId     String              @unique
  balance      Decimal             @default(0) @db.Decimal(12, 2)
  currency     String              @default("GHS")
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  transactions LedgerTransaction[]
  tenant       Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model LedgerTransaction {
  id          String         @id @default(uuid())
  ledgerId    String
  orderId     String?
  type        String
  amount      Decimal        @db.Decimal(12, 2)
  currency    String         @default("GHS")
  description String?
  meta        Json?
  createdAt   DateTime       @default(now())
  ledger      MerchantLedger @relation(fields: [ledgerId], references: [id], onDelete: Cascade)
  order       Order?         @relation(fields: [orderId], references: [id])
}

model PaystackEvent {
  id            String   @id @default(uuid())
  reference     String   @unique
  event         String
  tenantSlug    String?
  tenantId      String?
  amount        Decimal  @db.Decimal(12, 2)
  currency      String   @default("GHS")
  customerEmail String?
  customerName  String?
  rawPayload    Json
  processed     Boolean  @default(false)
  createdAt     DateTime @default(now())
}

model MerchantApplication {
  id             String         @id @default(uuid())
  fullName       String
  phone          String
  email          String?        @unique
  businessName   String
  businessType   String
  storeName      String
  whatYouSell    String
  basedIn        String
  monthlyRevenue String
  existingLinks  String?
  aiFamiliarity  String?
  aiUsedBefore   Boolean?
  aiToolsUsed    String?
  aiFeelings     String?
  allowAiHelp    String?
  status         MerchantStatus @default(pending)
  merchantId     String?        @unique
  createdBy      String?
  reviewNotes    String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([status])
  @@index([merchantId])
}

model OtpCode {
  id          String    @id @default(uuid())
  merchantId  String
  hashedCode  String
  expiresAt   DateTime
  used        Boolean   @default(false)
  attempts    Int       @default(0)
  lockedUntil DateTime?
  createdAt   DateTime  @default(now())

  @@index([merchantId])
  @@index([expiresAt])
}

enum MerchantStatus {
  pending
  approved
  rejected
  suspended
}
