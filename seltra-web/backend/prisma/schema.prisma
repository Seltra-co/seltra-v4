generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String?

  application  MerchantApplication?
  tenants      Tenant[]
  plan      String   @default("free")

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Tenant {
  id                    String            @id @default(uuid())
  ownerId               String?
  owner                 User? @relation(fields: [ownerId], references: [id])
  name                  String
  slug                  String            @unique
  businessType          String?
  city                  String?
  country               String?
  targetAudience        String?
  platform              String            @default("Seltra")
  status                String            @default("active")
  canonical             Json
  storeUrl              String?
  storefrontCode        String?
  storefrontVersion     Int               @default(0)
  storefrontGeneratedAt DateTime?
  manifest              Json?
  heroSource            String?
  heroGeneratedAt       DateTime?
  navSource             String?
  navGeneratedAt        DateTime?
  storeDNA              Json?
  merchantContext   Json?   // stores MerchantContext object
  merchantMemory         Json?
  brandVoice             Json?
  preferences            Json?
  payoutMethod           String?
  payoutProvider         String?
  payoutProviderCode     String?
  payoutAccount          String?
  payoutAccountName      String?
  payoutValidatedAt      DateTime?
  agentSettings          Json?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  categories            Category[]
  customers             Customer[]
  ledger                MerchantLedger?
  orders                Order[]
  paymentProviders      PaymentProvider[]
  products              Product[]
  shippingZones         ShippingZone[]
  events                TenantEvent[]
  invoices              Invoice[]
  agentEvents           AgentEvent[]
  disbursements         Disbursement[]
  marketingMessages     MarketingMessage[]
  marketingTemplates    MarketingTemplate[]

  aiCreditsUsed         Int      @default(0)
  aiCreditsWindowStart  DateTime @default(now())

  @@index([ownerId])
}

model TenantEvent {
  id String @id @default(uuid())
  tenantId String
  type TenantEventType
  meta Json?
  createdAt DateTime @default(now())
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([type, createdAt])
}

model OpsAuditLog {
  id         String   @id @default(uuid())
  actorLabel String
  action     String
  targetType String
  targetId   String
  payload    Json?
  createdAt  DateTime @default(now())

  @@index([targetType, targetId])
  @@index([actorLabel, createdAt])
}

model Conversation {
  id        String    @id
  title     String
  userId    String    @map("user_id")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  messages  Message[]

  @@index([userId, updatedAt(sort: Desc)], map: "Conversation_user_updated_idx")
  @@map("Conversation")
}

model Message {
  id             String       @id
  conversationId String       @map("conversation_id")
  userId         String       @map("user_id")
  role           String
  content        String
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt], map: "Message_conversation_created_idx")
  @@map("Message")
}

model Category {
  id       String @id @default(uuid())
  tenantId String
  name     String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name])
}

model Product {
  id          String           @id @default(uuid())
  tenantId    String
  name        String
  description String?
  price       Decimal          @db.Decimal(10, 2)
  currency    String           @default("GHS")
  category    String?
  sku         String?
  tags        Json?
  status      String           @default("active")
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  images      ProductImage[]
  variants    ProductVariant[]
}

model ProductImage {
  id        String  @id @default(uuid())
  productId String
  url       String
  isPrimary Boolean @default(false)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductVariant {
  id        String  @id @default(uuid())
  productId String
  name      String
  value     String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model PaymentProvider {
  id       String @id @default(uuid())
  tenantId String
  provider String
  config   Json?
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, provider])
}

model ShippingZone {
  id           String  @id @default(uuid())
  tenantId     String
  name         String
  deliveryTime String?
  fee          String?
  metadata     Json?
  tenant       Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name])
}

model Order {
  id              String              @id @default(uuid())
  tenantId        String
  customerId      String?
  customerEmail   String
  customerName    String?
  customerPhone   String?
  shippingAddress String?
  shippingCity    String?
  shippingCountry String?
  marketingOptIn  Boolean             @default(false)
  totalAmount     Decimal             @db.Decimal(10, 2)
  currency        String              @default("GHS")
  status          String              @default("pending")
  paystackRef     String?
  items           Json
  disbursed       Boolean             @default(false)
  disbursedAt     DateTime?
  seltraFee       Decimal?            @db.Decimal(10, 2)
  merchantAmount  Decimal?            @db.Decimal(10, 2)
  lastReminderAt  DateTime?
  fulfilledBy     String?
  trackingNumber  String?
  timeline        Json?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  ledgerTx        LedgerTransaction[]
  customer        Customer?           @relation(fields: [customerId], references: [id])
  tenant          Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, customerEmail])
  @@index([customerId])
}

model Customer {
  id             String   @id @default(uuid())
  tenantId       String
  email          String
  name           String?
  phone          String?
  address        String?
  city           String?
  country        String?
  marketingOptIn Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orders         Order[]
  lastContactedAt DateTime?
  lifetimeValue   Decimal? @db.Decimal(12, 2)
  preferredChannel String?
  notes            String?

  @@unique([tenantId, email])
  @@index([tenantId, updatedAt])
}

model MerchantLedger {
  id           String              @id @default(uuid())
  tenantId     String              @unique
  balance      Decimal             @default(0) @db.Decimal(12, 2)
  currency     String              @default("GHS")
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  transactions LedgerTransaction[]
  disbursements Disbursement[]
  tenant       Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model LedgerTransaction {
  id          String         @id @default(uuid())
  ledgerId    String
  orderId     String?
  type        String
  amount      Decimal        @db.Decimal(12, 2)
  currency    String         @default("GHS")
  description String?
  meta        Json?
  createdAt   DateTime       @default(now())
  ledger      MerchantLedger @relation(fields: [ledgerId], references: [id], onDelete: Cascade)
  order       Order?         @relation(fields: [orderId], references: [id])
}

model Disbursement {
  id             String   @id @default(uuid())
  tenantId       String
  ledgerId       String
  amount         Decimal  @db.Decimal(12, 2)
  currency       String   @default("GHS")
  status         String   @default("pending_otp")
  provider       String?
  providerCode   String?
  account        String
  accountName    String?
  externalRef    String   @unique
  transactionId  String?
  rawResponse    Json?
  otpHash        String?
  otpExpiresAt   DateTime?
  confirmedAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ledger         MerchantLedger @relation(fields: [ledgerId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([status])
}

model Invoice {
  id            String        @id @default(uuid())
  tenantId      String
  number        String
  customerName  String
  customerEmail String
  subtotal      Decimal       @db.Decimal(12, 2)
  tax           Decimal       @default(0) @db.Decimal(12, 2)
  discount      Decimal       @default(0) @db.Decimal(12, 2)
  total         Decimal       @db.Decimal(12, 2)
  currency      String        @default("GHS")
  status        String        @default("draft")
  dueDate       DateTime?
  pdfUrl        String?
  sentAt        DateTime?
  paidAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items         InvoiceItem[]

  @@unique([tenantId, number])
  @@index([tenantId, createdAt])
  @@index([status, dueDate])
}

model InvoiceItem {
  id          String   @id @default(uuid())
  invoiceId   String
  description String
  quantity    Int      @default(1)
  unitPrice   Decimal  @db.Decimal(12, 2)
  total       Decimal  @db.Decimal(12, 2)
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model AgentEvent {
  id        String   @id @default(uuid())
  tenantId  String?
  agent     String
  type      String
  action    String?
  payload   Json?
  status    String   @default("recorded")
  createdAt DateTime @default(now())
  tenant    Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([agent, createdAt])
}

model MarketingMessage {
  id             String   @id @default(uuid())
  tenantId       String
  channel        String
  audience       String
  subject        String?
  message        String
  recipientCount Int      @default(0)
  sent           Int      @default(0)
  failed         Int      @default(0)
  status         String   @default("sent")
  customerId     String?
  customerName   String?
  createdAt      DateTime @default(now())
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([channel, status])
}

model MarketingTemplate {
  id        String   @id @default(uuid())
  tenantId  String
  channel   String
  name      String
  subject   String?
  message   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, updatedAt])
}

model PaystackEvent {
  id            String   @id @default(uuid())
  reference     String   @unique
  event         String
  tenantSlug    String?
  tenantId      String?
  amount        Decimal  @db.Decimal(12, 2)
  currency      String   @default("GHS")
  customerEmail String?
  customerName  String?
  rawPayload    Json
  processed     Boolean  @default(false)
  createdAt     DateTime @default(now())
}

model MerchantApplication {
  id             String         @id @default(uuid())
  fullName       String
  phone          String
  email          String        @unique
  businessName   String
  businessType   String
  storeName      String
  whatYouSell    String
  basedIn        String //(city/state/country)
  monthlyRevenue String
  existingLinks  String?
  aiFamiliarity  String?
  aiUsedBefore   Boolean?
  aiToolsUsed    String?
  aiFeelings     String?
  allowAiHelp    String?
  status         MerchantStatus @default(pending)
  merchantId     String?        @unique
  userId         String?  @unique
  user           User?    @relation(fields: [userId], references: [id])
  createdBy      String?
  reviewNotes    String?
  reviewedAt     DateTime?
  credentialsGeneratedAt DateTime?
  welcomeEmailSentAt DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([status])
  @@index([merchantId])
}

model OtpCode {
  id          String    @id @default(uuid())
  merchantId  String
  hashedCode  String
  expiresAt   DateTime
  used        Boolean   @default(false)
  attempts    Int       @default(0)
  lockedUntil DateTime?
  createdAt   DateTime  @default(now())

  @@index([merchantId])
  @@index([expiresAt])
}

enum MerchantStatus {
  pending
  approved
  rejected
  suspended
}

enum TenantEventType {
  product_added
  order_placed
  order_status_updated
  payment_received
  invoice_created
  invoice_paid
  invoice_sent
  order_reminder
  sales_summary
  login
  settings_changed
  theme_updated
  ai_invocation
  merchant_onboarded
  disbursement_requested
  disbursement_paid
}

